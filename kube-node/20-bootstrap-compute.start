#!/bin/sh
# Phase 2 (compute): k3s agent.
[ -f /etc/local.d/20-bootstrap.done ] && exit 0
set -e
# Run under the local service, so log to a file and set a full PATH (the service
# environment is minimal — same reason 10-provision.start exports PATH).
exec >>/var/log/bootstrap.log 2>&1
export PATH="/usr/sbin:/usr/bin:/sbin:/bin:$PATH"

apk add -q curl procps

cat > /etc/sysctl.d/99-k3s.conf <<EOF
kernel.panic=10
kernel.panic_on_oops=1
vm.overcommit_memory=1
EOF
sysctl -p /etc/sysctl.d/99-k3s.conf

mount --make-rshared /
cat > /etc/local.d/00-rshared.start <<'EOF'
#!/bin/sh
mount --make-rshared /
EOF
chmod +x /etc/local.d/00-rshared.start

K3S_TOKEN_FILE="/etc/k3s-token"
[ -f "$K3S_TOKEN_FILE" ] || { echo "ERROR: $K3S_TOKEN_FILE not found." >&2; exit 1; }

curl -sfL https://get.k3s.io | \
  K3S_URL="https://10.0.0.22:6443" \
  K3S_TOKEN="$(cat "$K3S_TOKEN_FILE")" \
  INSTALL_K3S_EXEC="--protect-kernel-defaults" \
  sh -

rc-service k3s-agent restart

# vg-nvme backs TopoLVM's node-local volumes (homelab-topolvm chart); nvme0n1p3 is the
# same ex-Ceph partition, now an LVM PV instead of a Ceph OSD. compute-spot shares this
# script but has no p3 (root claims the whole disk, see 10-provision.start), so skip
# when the device isn't there.
if [ -b /dev/nvme0n1p3 ]; then
  apk add -q lvm2
  pvcreate /dev/nvme0n1p3
  vgcreate vg-nvme /dev/nvme0n1p3
fi

touch /etc/local.d/20-bootstrap.done
echo "==> k3s compute bootstrap complete. Run from control plane:"
echo "  kubectl label nodes $(hostname) gvisor=true"
[ -b /dev/nvme0n1p3 ] && echo "  kubectl label nodes $(hostname) vg=nvme"
